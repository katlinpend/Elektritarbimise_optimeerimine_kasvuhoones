
POSTGRES_USER=praktikum
POSTGRES_PASSWORD=praktikum
POSTGRES_DB=praktikum

DB_PORT_HOST=55432
DASHBOARD_PORT_HOST=8501

SOURCE_API_URL=https://api.open-meteo.com/v1/forecast
ELERING_API_URL=https://dashboard.elering.ee/api/nps/price

# Day-ahead hinnaloogika tõttu kasutame lühikest prognoosiakent.
FORECAST_DAYS=2
LOOKBACK_HOURS=48

# Croni vorming: minut tund kuupaev kuu nadalapaev
PIPELINE_CRON="0 * * * *"
RUN_ON_STARTUP=true

DASHBOARD_AUTOREFRESH_SECONDS=15

OPEN_METEO_LAT=58.3776
OPEN_METEO_LON=26.7290
OPEN_METEO_TIMEZONE=Europe/Tallinn
# Hinnanguline seadme elektritarbimine tunnis (küte või ventilatsioon)
DEVICE_POWER_KW=5



